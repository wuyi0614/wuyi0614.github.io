@article{ho2026datacenter,
  abbr        = {Proc. Natl. Acad. Sci. USA},
  title       = {Large Data Center Expansion Raises Residential Electricity Prices},
  author      = {Ho, H. and Wu, Yi},
  journal     = {Proceedings of the National Academy of Sciences},
  year        = {2026},
  note        = {Submitted. Equal contribution.},
  abstract    = {Power-hungry data centers are expanding with artificial intelligence, raising concerns that utility infrastructure costs are shifted to households. We study U.S. utilities around their first large data center, which often marks the start of a broader build out rather than a single facility. Average residential electricity prices are stable before entry but rise afterward, increasing by 0.42 cents/kWh after two years, about $3 per month for the average customer. The added cost is regressive: as a share of income, the increase is eight times larger for households with income below $30,000 than for households with income above $100,000, even as survey evidence suggests that workplace AI use and exposure are higher among higher income workers. Rate case filings provide complementary evidence from the regulatory process: investor owned utilities serving new large data centers request larger revenue increases after 2020.},
  selected    = {true}
}

